# Copy to .env and fill in. .env is gitignored.
# Required for handwriting grading (get one at https://console.anthropic.com):
ANTHROPIC_API_KEY=sk-ant-...

# Optional: cheaper grading model (pennies/night). Default is claude-opus-4-8.
# GRADING_MODEL=claude-haiku-4-5

# Optional: Gladys's real (ElevenLabs) voice on the display screen. Without BOTH
# of these she falls back to the browser's built-in voice. Get a key at
# https://elevenlabs.io; create the voice id once with
# `python3 scripts/design_gladys_voice.py` and paste it here.
# ELEVENLABS_API_KEY=
# GLADYS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2

# Optional: where the SQLite db and uploaded photos live (defaults shown).
# TRIVIA_DB=trivia.db
# TRIVIA_UPLOADS=uploads
