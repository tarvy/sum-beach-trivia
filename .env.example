# Copy to .env and fill in. .env is gitignored.
# Required for handwriting grading (get one at https://console.anthropic.com):
ANTHROPIC_API_KEY=sk-ant-...

# Optional: cheaper grading model (pennies/night). Default is claude-opus-4-8.
# GRADING_MODEL=claude-haiku-4-5

# Optional: where the SQLite db and uploaded photos live (defaults shown).
# TRIVIA_DB=trivia.db
# TRIVIA_UPLOADS=uploads
